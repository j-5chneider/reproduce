@incollection{erickson.2006,
	address = {Mahwah,  NJ,  US},
	title = {Definition and {Analysis} of {Data} from {Videotape}: {Some} {Research} {Procedures} and {Their} {Rationales}.},
	isbn = {0-8058-5932-2 (Hardcover); 0-8058-5933-0 (Paperback); 9780805859331 (Hardcover)},
	abstract = {Routine social interaction has proved elusive as researchers attempt to study it. Its moment-by-moment conduct is so complex and nuanced, and, as an assembly of habits in use, its conduct is so transparent to persons as they are engaged in it that information about it can only very imprecisely be derived from interviews or surveys, or from observational checklists, or even from the field notes of participant observers. Rather, fine-grained information about the actual conduct of social interaction comes best from making audiovisual recordings of it from which either detailed transcriptions of the interaction can be prepared and analyzed or careful moment-by- moment coding can be done. Currently the recording medium of choice is videotape. The use of videotape as a primary information source (in combination with video-based interviewing of informants) is the topic of this chapter. The discussion emphasizes the analysis of interactional records collected in school classrooms, but the principles for videotaping and video analysis apply to the study of everyday social interaction in any of the situations in which it might take place. (PsycInfo Database Record (c) 2024 APA, all rights reserved)},
	booktitle = {Handbook of complementary methods in education research.},
	publisher = {Lawrence Erlbaum Associates Publishers},
	author = {Erickson, Frederick},
	year = {2006},
	keywords = {*Analysis, *Interviewing, *Social Interaction, *Videotapes, Experimentation},
	pages = {177--191},
}

