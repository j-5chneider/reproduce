	pages = {47--55},
	file = {Volltext:C\:\\Users\\schneider08ka\\Zotero\\storage\\NEHLPLUE\\Landi et al. - 2020 - The “A” of FAIR – As Open as Possible, as Closed a.pdf:application/pdf},
