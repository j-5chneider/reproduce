@article{hartmann.2017,
	title = {The {Potentials} of {Using} {Cloud} {Computing} in {Schools}: {A} {Systematic} {Literature} {Review}},
	volume = {16},
	issn = {2146-7242},
	shorttitle = {The {Potentials} of {Using} {Cloud} {Computing} in {Schools}},
	url = {https://eric.ed.gov/?id=EJ1124903},
	abstract = {Cloud Computing (CC) refers to the physical structure of a communications network, where data is stored in large data centers and can be accessed anywhere, at any time, and from different devices. This systematic literature review identifies and categorizes the potential and barriers of cloud-based teaching in schools from an international perspective. This study applied the Preferred Reporting Items for Systematic Reviews and Meta-Analyses (PRISMA) methodology for determining the articles and reporting analysis. A total of 510 articles were identified from ERIC, IEEE Xplore, Science Direct, and Primo. After screening and eligibility checking, 13 articles focusing on "cloud computing and school" were included for qualitative and meta-analysis. The papers are coded, devising 31 themes grouped into five categories. The adoption of CC in schools is associated with five factors: 1) globalization (easier access to education, data access everywhere/accessibility/infrastructure, 21st Century Skills); 2) educational benefits (motivation, teacher-parent communication, collaboration, flexibility, productivity, creativity, self-organized learning, communication, sharing of knowledge, problem-solving, responsible students/peer review/no bad excuses); 3) administrative benefits (economy–operations, computer lifetime, licenses, timesaving, BYOD, software diversity); 4) barriers (technical barriers, cultural barriers, security, privacy, laws and regulations for schools, age restrictions/parent acceptance, and opacity); and 5) implementation (management support, paradigm shift in education, incongruence between implementation strategies).},
	language = {English},
	number = {1},
	urldate = {2019-10-02},
	journal = {Turkish Online Journal of Educational Technology - TOJET},
	author = {Hartmann, Simon Birk and Braae, Lotte Qulleq Nygaard and Pedersen, Sine and Khalid, Md Saifuddin},
	month = jan,
	year = {2017},
	keywords = {Barriers, Computer Uses in Education, Access to Education, Access to Information, Coding, Computer Software, Educational Administration, Educational Methods, Educational Technology, Elementary Secondary Education, Global Approach, Information Management, Internet, Meta Analysis, Program Implementation, Qualitative Research},
	pages = {190--202},
	file = {Full Text PDF:C\:\\Users\\schneider08ka\\Zotero\\storage\\L8R7KJED\\Hartmann et al. - 2017 - The Potentials of Using Cloud Computing in Schools.pdf:application/pdf;Snapshot:C\:\\Users\\schneider08ka\\Zotero\\storage\\K8E4B3LR\\eric.ed.gov.html:text/html},
