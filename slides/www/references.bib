	year = {2017},
	keywords = {Bildungsforschung, Educational research, Deutschland, Germany, Forschung, Datenanalyse, Vergleich, Modell, Empirical study, Empirische Untersuchung, Research, Kompetenz, Competency, Design, Higher education, Hochschulbildung, Structural model, Strukturmodell, Test coaching, Testverfahren, University level of education},
	pages = {37--68},
