@article{courtland.2010,
	title = {Beliefs and {Practices} of {Three} {Literacy} {Instructors} in {Elementary} {Teacher} {Education}},
	volume = {56},
	issn = {00024805},
	abstract = {This article describes the beliefs and practices of three literacy teacher educators at one site of a longitudinal multisite case study of teacher education and literacy teaching that describes teacher candidates' experiences in literacy courses and their first two years of literacy teaching. One instructor held a social constructivist perspective and focused on depth of conceptual understanding; two promoted breadth to prepare the students for the early years of teaching. The courses highlighted print literacy. Neither critical literacy, multiliteracies, or multimodality were emphasized. Instructors perceived that their students were prepared to teach literacy, but noted inconsistencies between their courses and practices in the field experience. (English) [ABSTRACT FROM AUTHOR] Cet article décrit les croyances et les pratiques de trois formateurs d'enseignants en alphabétisation dans un des milieux d'une étude de cas longitudinale et multisite portant sur la formation des enseignants et sur l'alphabétisatio. On décrit les expériences de stagiaires dans des cours d'alphabétisation et lors de leurs deux premières années comme alphabétiseurs. Les croyances d'un des formateurs s'inscrivaient dans une perspective socio-constructive et portaient sur la profondeur de la compréhension conceptuelle ; les deux autres instructeurs favorisaient l'étendue des connaissances dans la préparation des étudiants pour les premières années de l'enseignement. Le cours mettait l'écrit au premier plan. Ni la littératie critique, les littératies multiples ou la multimodalité n'étaient mises en évidence. Les formateurs estimaient que leurs étudiants étaient prêts à enseigner en alphabétisation, mais ils ont noté des incohérences entre leurs cours et les pratiques lors des activités sur le terrain. (French) [ABSTRACT FROM AUTHOR]},
