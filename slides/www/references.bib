@incollection{patry.2012,
	title = {Der {Pädagogische} {Takt}},
	abstract = {Herbart bezeichnet den "Pädagogischen Takt" als Zwischenglied zwischen Theorie und Praxis. Ausgehend von den (wenigen) theoretischen Überlegungen zum Takt und Erkenntnissen aus anderen Diskussionen sollen Elemente zu einer "Theorie des Taktes" entwickelt werden. Dabei wird zwischen Theorien1 (Theorien, die mittels Takt in praktisches Tun zu "übersetzen" sind) und Theorien2 (theoretische Aussagen über den Takt) unterschieden. Praxis wird als Handeln bestimmt. Theorien1 können dann nur handlungswirksam werden, wenn sie die Praktikerin oder der Praktiker in das System handlungsleitender subjektiver Theorien aufgenommen hat. Für das taktvolle Handeln sind sodann folgende Elemente zu berücksichtigen: Komplexität (Theorien1 vereinfachen die Phänomene zwangsläufig, in der Praxis muss aber der ganzen Komplexität Rechnung getragen werden), damit zusammenhängend die Allgemeinheits-Konkretheits-Antinomie ("Je allgemeiner eine Aussage ist, desto weniger konkret kann sie sein"), Zielvielfalt (Praktikerinnen und Praktiker verfolgen fast immer mehrere, auch entgegengesetzte Ziele simultan), die Theorienvielfalt (bezogen auf Theorien1; Praktikerinnen und Praktiker verwenden fast immer mehrere Theorien1 simultan) und Situationsspezifität (in unterschiedlichen Situationen ist meist unterschiedliches Verhalten zielführend). Hinzu kommen ethische Überlegungen. Auf diesen Elementen aufbauend wird ein Modell der Dynamik des Pädagogischen Taktes entwickelt, welches so konzipiert ist, dass die Praktikerin oder der Praktiker eine substanzielle kreative Leistung zu erbringen hat - in dieser liegt ein wesentlicher Teil ihrer oder seiner Verantwortung. (DIPF/Orig.).},
	booktitle = {Enzyklopädie {Erziehungswissenschaft} online. {Fachgebiet} {Schulpädagogik}},
	author = {Patry, Jean-Luc},
	editor = {Rahm, Sibylle and Nerowski, Christian},
	month = jan,
	year = {2012},
	keywords = {Lehrer, Pädagogisches Handeln, Praxis, Theorie, Begriff, Definition, Pädagogik, Herbart, Johann Friedrich, Menschenwürde, Persönlichkeitsmerkmal, Subjektive Theorie, Taktgefühl, Verantwortung},
	file = {Full Text:C\:\\Users\\schneider08ka\\Zotero\\storage\\IICBAJ78\\Patry, J.-L. (2012). Der Pädagogische Takt.pdf:application/pdf},
}

