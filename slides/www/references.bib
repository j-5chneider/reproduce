@article{schneider.2025a,
	title = {Bereitstellen und {Nachnutzen} von {Unterrichtsvideos}: {Ein} {Leitfaden} mit {Ressourcen} für {Forschende}},
	volume = {53},
	issn = {0340-4099, 2520-873X},
	shorttitle = {Bereitstellen und {Nachnutzen} von {Unterrichtsvideos}},
	url = {https://link.springer.com/10.1007/s42010-025-00234-8},
	doi = {10.1007/s42010-025-00234-8},
	abstract = {Zusammenfassung
            Unterrichtsvideos stellen wie kaum ein anderer Datentyp die Prozesse des Unterrichts komplexitätserhaltend dar und bieten damit ein enormes Analysepotenzial. Somit konnten Videostudien in der Vergangenheit bereits wegweisende Erkenntnisse über unterrichtliche Prozesse und Praktiken liefern. Eine bedeutende Stärke von Videoforschungsdaten liegt in ihrer Nutzbarkeit zur Beantwortung von Forschungsfragen über Forschungsparadigmen hinweg. Entsprechend gilt die Bereitstellung und Nachnutzung von Unterrichtsvideos als wertvoller Ansatz der Unterrichtsforschung. Bisher ist es allerdings nicht gelungen, eine Kultur der Bereitstellung und Nachnutzung deutschsprachiger Unterrichtsvideos zu etablieren. Forschende berichten dabei weiterhin von Unsicherheiten an zahlreichen Stellen entlang des Forschungsprozesses. Ziel des Beitrags ist es, Arbeitsschritte und Ressourcen für Forschende bezüglich der Bereitstellung und Nachnutzung von Unterrichtsvideos zu systematisieren. Dies soll Unsicherheiten im Prozess verringern und den Arbeitsaufwand für die Forschenden möglichst reduzieren. Anhand eines Prozessmodells werden wesentliche Arbeitsschritte für eine Bereitstellung oder Nachnutzung beschrieben und jeweilige Ressourcen aufgezeigt. Der Beitrag schärft das Bewusstsein für die gemeinsame Nutzung von Unterrichtsvideos und stellt deren Attraktivität für die Bildungsforschung und die Forschenden selbst heraus. Gleichzeitig wird aufgezeigt, an welchen Stellen noch Ressourcen und empirische Erkenntnisse fehlen, um eine Kultur der Bereitstellung und Nachnutzung weiter auszubauen.
          , 
            Abstract
            Classroom videos capture the processes of teaching in a way that preserves complexity like hardly any other type of data and thus offer enormous potential for analysis. Thus, in the past, video studies have already been able to provide groundbreaking insights into instructional processes and practices. A significant strength of video research data lies in its usefulness for answering research questions across research paradigms. Accordingly, the provision and reuse of classroom videos is considered a valuable approach to research on instruction. To date, however, a culture of sharing and reusing German classroom videos has not been successfully established. Researchers continue to report uncertainties at numerous points along the research process. The goal of this paper is to systematize steps and resources for researchers regarding sharing and reuse of classroom videos. We aim to reduce uncertainties in the process and to reduce the workload for researchers in this process. For this purpose, essential steps for sharing or reusing classroom videos are described and respective resources are pointed out. The paper raises awareness of the process of sharing and reusing classroom videos and highlights their attractiveness for educational research and the researchers themselves. At the same time, it highlights where resources and empirical evidence are still lacking to further develop a culture of provision and reuse.},
	language = {de},
	number = {3},
	urldate = {2025-06-25},
	journal = {Unterrichtswissenschaft},
	author = {Schneider, Jürgen and Schreyer, Patrick and Kunter, Mareike and Porzelt, Maike},
	month = jun,
	year = {2025},
	pages = {369--398},
	file = {Full Text PDF:C\:\\Users\\schneider08ka\\Zotero\\storage\\W5Y5KF2D\\Schneider et al. - 2025 - Bereitstellen und Nachnutzen von Unterrichtsvideos Ein Leitfaden mit Ressourcen für Forschende.pdf:application/pdf},
}

@article{lohse-bossenz.2024,
	title = {Inkongruente {Erwartungen} an den {Vorbereitungsdienst} als {Prädiktoren} emotionaler {Erschöpfung}},
	volume = {38},
	copyright = {https://creativecommons.org/licenses/by-nd/4.0},
	issn = {1010-0652, 1664-2910},
	url = {https://econtent.hogrefe.com/doi/10.1024/1010-0652/a000332},
	doi = {10.1024/1010-0652/a000332},
	abstract = {Zusammenfassung. Die vorliegende Studie untersucht die wahrgenommene Erfüllung von Erwartungen von Lehramtsanwärterinnen und -anwärtern an den Vorbereitungsdienst. Basierend auf empirischen Befunden aus der Arbeits- und Organisationspsychologie wird erwartet, dass nicht-erfüllte Erwartungen an den Vorbereitungsdienst mit einem Anstieg an emotionaler Erschöpfung assoziiert sein könnten. Es wurden 1109 Lehramtsanwärterinnen und -anwärter der Sekundarstufe I zu Beginn des Vorbereitungsdienstes (Erwartungen) und ein Jahr später (erfüllte Erwartungen) mit einer neu entwickelten Skala zu positiven („ Nutzen“) und negativen („ Kosten“) Wahrnehmungen des Vorbereitungsdienstes sowie ihrer emotionalen Erschöpfung befragt. Die Kosten-Nutzen-Skala konnte (erfüllte) Erwartungen an den Vorbereitungsdienst zu beiden Messzeitpunkten ausreichend gut erfassen. Auch die emotionale Erschöpfung wurde reliabel erfasst, wobei ein signifikanter Anstieg an emotionaler Erschöpfung im Untersuchungszeitraum festgestellt wurde. Response Surface Analysen wiesen auf einen Anstieg an emotionaler Erschöpfung im Untersuchungszeitraum hin, wenn Erwartungen an den Vorbereitungsdienst bezüglich dessen Kosten und Nutzen nicht mit der tatsächlichen Wahrnehmung übereinstimmten. Die Ergebnisse werden auf der Grundlage der aktuellen empirischen Befundlage diskutiert. Zuletzt wird ein Ausblick auf anschließende Forschungsarbeiten gegeben.},
	language = {en},
	number = {1-2},
	urldate = {2025-06-23},
	journal = {Zeitschrift für Pädagogische Psychologie},
	author = {Lohse-Bossenz, Hendrik and Rutsch, Juliane and Spinath, Birgit and Dörfler, Tobias},
	month = jan,
	year = {2024},
	pages = {117--130},
}

