	file = {Schmid und Lutz - 2007 - Epistemologische Überzeugungen als kohärente Laien.pdf:C\:\\Users\\schneider08ka\\Zotero\\storage\\IBCBHSM3\\Schmid und Lutz - 2007 - Epistemologische Überzeugungen als kohärente Laien.pdf:application/pdf},
