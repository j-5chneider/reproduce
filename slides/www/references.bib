@book{oecd.2015,
	address = {Paris},
	title = {Bildung auf einen {Blick} 2015: {OECD} {Indikatoren}},
	isbn = {978-3-7639-5628-9},
	abstract = {Die OECD-Länder müssen stärkere Anstrengungen unternehmen, die Ungleichheit in der Bildung weiter abzubauen und gleichzeitig die Effektivität ihrer Bildungssysteme erhöhen. Nur so kann sichergestellt werden, dass jedes Kind  unabhängig von seiner Herkunft  sein Potential voll entfalten kann und von einer guten Bildung profitiert. Die aktuelle Ausgabe der OECD-Studie "Bildung auf einen Blick" bietet einen Überblick über die Bildungssysteme in den 34 Ländern der OECD und einer Reihe von Partnerländern. Schwerpunktthemen sind die frühkindliche Bildung bis zum Sekundarbereich II, der Lehrerberuf, das Bildungsniveau, Kompetenzen und Erwerbsbeteiligung sowie Chancengerechtigkeit im Bildungswesen und auf dem Arbeitsmarkt.},
