	note = {Num Pages: 22},
	keywords = {Instructional Design, Learning Processes, Cognitive Style, Computer Assisted Instruction, Electronic Learning, English (Second Language), Gender Differences, Individualized Instruction, Intelligent Tutoring Systems, Learning Motivation, Pretests Posttests, Programming, Second Language Instruction, Student Characteristics},
	pages = {66--87},
