	file = {PDF:C\:\\Users\\schneider08ka\\Zotero\\storage\\Y68IA8SW\\Sherin et al. - 2009 - Selecting Video Clips to Promote Mathematics Teachers' Discussion of Student Thinking.pdf:application/pdf},
}

