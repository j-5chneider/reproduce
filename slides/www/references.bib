@book{kelle.2010,
	address = {Wiesbaden},
	edition = {2., überarb. Aufl.},
	title = {Vom {Einzelfall} zum {Typus}: {Fallvergleich} und {Fallkontrastierung} in der qualitativen {Sozialforschung}},
	isbn = {978-3-531-14704-8},
	url = {http://dx.doi.org/10.1007/978-3-531-92366-6},
