@article{clark.2012,
	title = {Putting {Students} on the {Path} to {Learning}: {The} {Case} for {Fully} {Guided} {Instruction}},
	volume = {36},
	issn = {0148-432X},
	shorttitle = {Putting {Students} on the {Path} to {Learning}},
	url = {https://eric.ed.gov/?id=EJ971752},
	abstract = {Disputes about the impact of instructional guidance during teaching have been ongoing for more than a half century. On one side of this argument are those who believe that all people--novices and experts alike--learn best when provided with instruction that contains unguided or partly guided segments. On the other side are those who believe that ideal learning environments for experts and novices differ: while experts often thrive without much guidance, nearly everyone else thrives when provided with full, explicit instructional guidance. The goal of this research is to put an end to this debate. Discovery learning, problem-based learning, inquiry learning, constructivist learning--whatever the label, teaching that only partially guides students, and expects them to discover information on their own, is not effective or efficient. Decades of research clearly demonstrate that when teaching new information or skills, step-by-step instruction with full explanations works best. (Contains 37 endnotes.)},
	language = {en},
	number = {1},
	urldate = {2022-04-13},
	journal = {American Educator},
	publisher = {American Federation of Teachers},
	author = {Clark, Richard E. and Kirschner, Paul A. and Sweller, John},
	year = {2012},
	keywords = {Instructional Effectiveness, Teaching Methods, Best Practices, Constructivism (Learning), Discovery Learning, Educational Strategies, Evidence, Guidance, Inquiry, Intermode Differences, Learning Strategies, Neuropsychology, Problem Based Learning, Scaffolding (Teaching Technique)},
	pages = {6--11},
	file = {Clark et al. - 2012 - Putting Students on the Path to Learning The Case.pdf:C\:\\Users\\schneider08ka\\Zotero\\storage\\JK2E7W45\\Clark et al. - 2012 - Putting Students on the Path to Learning The Case.pdf:application/pdf;Snapshot:C\:\\Users\\schneider08ka\\Zotero\\storage\\9G4AGNII\\eric.ed.gov.html:text/html},
