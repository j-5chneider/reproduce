	author = {Heck, Tamara and Blümel, Ina and Fahrer, Sigrid and Lohner, David and Schneider, Jürgen and Visser, Linda},
	month = apr,
	year = {2020},
	keywords = {open science, educational research, open educational practices, science studies, wissenschaftsforschung},
}

