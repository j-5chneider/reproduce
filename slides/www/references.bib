	doi = {10.21240/mpaed/20/2011.09.11.x},
	abstract = {In dem Beitrag geht es zunächst um die Fragen, in welchen Zusammenhängen die Begriffe Medienpädagogik, Medienerziehung, Mediendidaktik, Medienkompetenz und Medienbildung entstanden sind, in welchem Verhältnis sie zueinander stehen und mit welchem Verständnis sie im Laufe der Entwicklung verwendet wurden. Damit soll ein vertieftes Verständnis der Begriffe und ihrer Bedeutung für die pädagogische Auseinandersetzung mit Medien erreicht werden. Zugleich lassen sich so unterschiedliche Auffassungen zum jeweiligen Begriffsinhalt einordnen bzw. aufklären. Vor diesem Hintergrund werden Empfehlungen zur zukünftigen Begriffsverwendung und zu einer möglichen Strukturierung der Medienpädagogik formuliert.},
