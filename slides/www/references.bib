@incollection{kuhn.2002,
	address = {Mahwah, NJ, US},
	title = {What is epistemological thinking and why does it matter?},
	isbn = {978-0-8058-3518-2},
	abstract = {Areview of the existing epistemic developmental models (B. K. Hofer and P. R. Pintrich, 1997) suggests that each of the primary models posit developmental trajectories that parallel one another. Regardless of the number of stages, positions, or perspectives, the sequence invariably suggests movement from a dualistic, objectivist view of knowledge to a more subjective, relativistic stance and ultimately to a contextual, constructivist perspective of knowing. In this chapter on epistemological thinking—and why it matters—the present authors identify the developmental tasks inherent in the growth of epistemological understanding. They suggest that it is this coordination of the subjective and objective dimensions of knowing that is the essence of epistemological development and describe their research in measuring the progression of this cognitive process from childhood to adulthood. Their work is an attempt to clarify and simplify our understanding of epistemological development and to situate it within our knowledge about cognitive development. (PsycINFO Database Record (c) 2016 APA, all rights reserved)},
	booktitle = {Personal epistemology:  {The} psychology of beliefs about knowledge and knowing},
	publisher = {Lawrence Erlbaum Associates Publishers},
