	pages = {71--94},
	file = {PDF:C\:\\Users\\schneider08ka\\Zotero\\storage\\YEYKRZHR\\Laugksch - 2000 - Scientific literacy A conceptual overview.pdf:application/pdf;Snapshot:C\:\\Users\\schneider08ka\\Zotero\\storage\\MQ3KRASZ\\(SICI)1098-237X(200001)84171AID-SCE63.0.html:text/html},
