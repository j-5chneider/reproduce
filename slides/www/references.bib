@article{schmid.2007,
	title = {Epistemologische Überzeugungen als kohärente {Laientheorien}},
	volume = {21},
	issn = {1010-0652, 1664-2910},
	url = {https://econtent.hogrefe.com/doi/10.1024/1010-0652.21.1.29},
	doi = {10.1024/1010-0652.21.1.29},
	abstract = {Zusammenfassung. Epistemologische Überzeugungen werden in der Pädagogischen Psychologie zumeist als unabhängige Dimensionen konzipiert. Wir nehmen demgegenüber an, dass Überzeugungen zur Sicherheit natur- und sozialwissenschaftlichen Wissens kohärente epistemologische Laientheorien bilden. Unterscheidet man zwischen ontologischen Aspekten (Realismus vs. Antirealismus), epistemologischen Aspekten (Erkenntnisoptimismus vs. -skeptizismus) und wissenschaftskritischen Aspekten (Wissenschaftsoptimismus vs. -pessimismus), können A-priori-Annahmen über die Kohärenz/Inkohärenz der kombinatorisch möglichen Überzeugungskonfigurationen formuliert werden. Die Ergebnisse einer Fragebogen- und einer Online-Untersuchung sprechen dafür, dass inkohärente Konfigurationen seltener sind, als bei Unabhängigkeit der drei Aspekte per Zufall zu erwarten wäre. In der Online-Untersuchung beurteilten die Pbn vorgegebene Überzeugungskonfigurationen hinsichtlich ihrer Kohärenz. Dies gelang ihnen selbst dann, wenn sie die entsprechenden Positionen nicht teilten. Die Ergebnisse sprechen für eine hohe Differenziertheit epistemologischer Überzeugungen und verdeutlichen die Möglichkeit und Notwendigkeit, sie auch entsprechend differenziert zu erfassen.},
	language = {de},
	number = {1},
	urldate = {2021-05-04},
	journal = {Zeitschrift für Pädagogische Psychologie},
	author = {Schmid, Sebastian and Lutz, Alexander},
	month = jan,
	year = {2007},
