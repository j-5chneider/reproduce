@article{mandl.1996,
	title = {Neue {Wege} des {Lernens} mit {Multimedia}: {Probleme} mit den alten {Wegen} des {Lernens}. {Fehlende} {Wissenschaftsanwendung}},
	volume = {7},
	abstract = {Der Transfer von Wissen bzw. die Anwendung des Wissens im Leben stellt ein Problem von Aus- und Weiterbildung dar. Multimediale Lernumgebungen können dazu beitragen, die Distanz zwischen Lernsituation und Anwendungssituation zu verringern und so das Ausmass an Authentizität des Lernens zu erhöhen. Zu beachten ist jedoch, dass die Kluft durch solche Systeme nicht vollständig geschlossen werden kann. Die Forderung nach Authentizität von Lernumgebungen kann jedoch durch Multimedia eher erfüllt werden als durch herkömmlichen Unterricht. Multimediales Lernen sollte als Bindeglied zwischen Schullernen und Anwendungspraxis gesehen werden. Ein Beispiel für eine multimediale Lernumgebung, die den Prinzipien situierten Lernens entsprechend gestaltet wurde, ist das Computerprogramm Thyroidea, das zur Aus-und Weiterbildung in der Medizin dient. Forschungsmethode: anwendungsorientiert.},
