@article{philip.2019,
	title = {Making {Justice} {Peripheral} by {Constructing} {Practice} as “{Core}”: {How} the {Increasing} {Prominence} of {Core} {Practices} {Challenges} {Teacher} {Education}},
	volume = {70},
	issn = {0022-4871},
	shorttitle = {Making {Justice} {Peripheral} by {Constructing} {Practice} as “{Core}”},
	url = {https://doi.org/10.1177/0022487118798324},
	doi = {10.1177/0022487118798324},
	abstract = {Reformers are increasingly calling for and adopting practice-based approaches to teacher preparation, with particular emphasis on identifying and centering core practices. In this article, we argue that organizing teacher education around core practices brings its own risks, including the risk of peripheralizing equity and justice. Situating our argument within the broad economic trends affecting labor and higher education in the 21st century, we begin by examining the linkages between the core practices movement and organizations that advocate market-based solutions to education. We then explore how constructs of practice and improvisation and commitments to equity and justice are taken up, and with what implications and consequences, in core practices scholarship and its applications. In conclusion, we consider how work being done around core practices might contribute to a collective struggle for greater equity and justice in schools and in society.},
	language = {en},
	number = {3},
	urldate = {2021-06-25},
	journal = {Journal of Teacher Education},
	publisher = {SAGE Publications Inc},
	author = {Philip, Thomas M. and Souto-Manning, Mariana and Anderson, Lauren and Horn, Ilana and J. Carter Andrews, Dorinda and Stillman, Jamy and Varghese, Manka},
	month = may,
	year = {2019},
	keywords = {education reform, class, equity, gender, preservice teacher education, race, sexual orientation, urban teacher education},
	pages = {251--264},
	file = {Philip et al. - 2019 - Making Justice Peripheral by Constructing Practice.pdf:C\:\\Users\\schneider08ka\\Zotero\\storage\\VTFAS4XU\\Philip et al. - 2019 - Making Justice Peripheral by Constructing Practice.pdf:application/pdf},
}

