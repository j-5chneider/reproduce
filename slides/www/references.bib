	note = {tex.ids: harfordetal.2008a},
	keywords = {Teacher education, Communities of practice, Peer videoing, Reflective practice},
	pages = {1884--1892},
	file = {ScienceDirect Snapshot:C\:\\Users\\schneider08ka\\Zotero\\storage\\T96E6VMM\\S0742051X08000255.html:text/html},
