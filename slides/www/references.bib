	pages = {201494},
	file = {Volltext:C\:\\Users\\schneider08ka\\Zotero\\storage\\2JASU5SB\\Hardwicke et al. - 2021 - Analytic reproducibility in articles receiving ope.pdf:application/pdf},
}

